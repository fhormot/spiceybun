# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

!.gitignore

# Virtual environments
.venv

# Test outputs
/tests/outputs/*

.coverage
htmlcov

# Library files - ignore everything in ng-libs except specific file types
/ng-libs/**

# Unignore directories so nested files can be re-included
!/ng-libs/**/

# Keep specific file types and spice init files
!/ng-libs/**/*.lib
!/ng-libs/**/*.osdi
!/ng-libs/**/.spiceinit